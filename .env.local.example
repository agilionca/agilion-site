# Copier vers .env.local et remplir les valeurs
# Ce fichier est ignore par git (.env.local est dans .gitignore)

FTP_HOST=ftp.agilion.ca
FTP_USER=votre_user_cpanel
FTP_PASS=votre_mot_de_passe
FTP_REMOTE_DIR=/public_html/
FTP_VENDOR_DIR=/vendor/   # Chemin relatif au home cPanel, AU-DESSUS de public_html
# Structure attendue sur le serveur :
#   /home/user/vendor/PHPMailer/    <- PHPMailer ici
#   /home/user/public_html/         <- dist/ ici
#   /home/user/config.php           <- copier manuellement (credentials)

# Cloudflare Turnstile (https://dash.cloudflare.com/)
PUBLIC_TURNSTILE_SITEKEY=votre_sitekey_publique

# Secrets GitHub Actions (ajouter dans Settings > Secrets > Actions)
# FTP_HOST, FTP_USER, FTP_PASS, FTP_REMOTE_DIR, FTP_VENDOR_DIR, ANTHROPIC_API_KEY
