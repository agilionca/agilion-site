# Copier vers .env.local et remplir les valeurs
# Ce fichier est ignore par git (.env.local est dans .gitignore)

FTP_HOST=ftp.agilion.ca
FTP_USER=votre_user_cpanel
FTP_PASS=votre_mot_de_passe
FTP_REMOTE_DIR=/public_html/

# Secrets GitHub Actions (ajouter dans Settings > Secrets > Actions)
# FTP_HOST, FTP_USER, FTP_PASS, FTP_REMOTE_DIR
# ANTHROPIC_API_KEY (pour la generation d'articles IA)
