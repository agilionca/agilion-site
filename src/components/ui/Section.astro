---
interface Props {
  id?: string;
  class?: string;
  bg?: 'white' | 'surface' | 'primary';
  as?: 'section' | 'div' | 'article';
}

const { id, class: className, bg = 'white', as: Tag = 'section' } = Astro.props;

const bgClasses: Record<string, string> = {
  white: 'bg-white',
  surface: 'bg-surface',
  primary: 'bg-primary text-white',
};

const classes = ['py-16 md:py-24', bgClasses[bg], className]
  .filter(Boolean)
  .join(' ');
---

<Tag id={id} class={classes}>
  <div class="container-site">
    <slot />
  </div>
</Tag>
