---
import { useTranslations, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
  /** URL du backend PHP, ex: '/api/contact.php' */
  action: string;
}

const { lang, action } = Astro.props;
const t = useTranslations(lang);

// Cloudflare Turnstile sitekey — remplacer par la vraie clé
const TURNSTILE_SITEKEY = '0x4AAAAAAA_PLACEHOLDER_SITEKEY';
---

<form
  id="contact-form"
  novalidate
  class="space-y-6"
  data-action={action}
  data-lang={lang}
>
  <!-- Honeypot — invisible pour les humains, piège pour les bots -->
  <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
    <label for="website" class="sr-only">{t('contact.honeypot')}</label>
    <input
      id="website"
      name="website"
      type="text"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <!-- Nom complet -->
  <div>
    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
      {t('contact.form.name')} <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <input
      id="name"
      name="name"
      type="text"
      required
      autocomplete="name"
      placeholder={t('contact.form.placeholder.name')}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-900 placeholder-gray-400"
    />
    <p id="name-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
  </div>

  <!-- Courriel / Email -->
  <div>
    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
      {t('contact.form.email')} <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <input
      id="email"
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder={t('contact.form.placeholder.email')}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-900 placeholder-gray-400"
    />
    <p id="email-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
  </div>

  <!-- Téléphone (optionnel) -->
  <div>
    <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
      {t('contact.form.phone')}
    </label>
    <input
      id="phone"
      name="phone"
      type="tel"
      autocomplete="tel"
      placeholder={t('contact.form.placeholder.phone')}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-900 placeholder-gray-400"
    />
  </div>

  <!-- Entreprise (optionnel) -->
  <div>
    <label for="company" class="block text-sm font-medium text-gray-700 mb-1">
      {t('contact.form.company')}
    </label>
    <input
      id="company"
      name="company"
      type="text"
      autocomplete="organization"
      placeholder={t('contact.form.placeholder.company')}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-900 placeholder-gray-400"
    />
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
      {t('contact.form.message')} <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      minlength="20"
      placeholder={t('contact.form.placeholder.message')}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-900 placeholder-gray-400 resize-y"
    ></textarea>
    <p id="message-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
  </div>

  <!-- Cloudflare Turnstile -->
  <div
    class="cf-turnstile"
    data-sitekey={TURNSTILE_SITEKEY}
    data-theme="light"
  ></div>

  <!-- Bouton submit -->
  <button
    id="submit-btn"
    type="submit"
    class="w-full px-8 py-4 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 active:scale-95 transition-all duration-150 text-lg shadow-md disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2"
  >
    <span id="btn-text">{t('contact.form.submit')}</span>
    <svg
      id="btn-spinner"
      class="hidden animate-spin h-5 w-5"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </button>
</form>

<!-- Alerte succès -->
<div
  id="success-alert"
  class="hidden mt-6 p-6 bg-green-50 border border-green-200 rounded-lg"
  role="alert"
  aria-live="polite"
>
  <div class="flex items-start gap-3">
    <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
      <h3 class="font-semibold text-green-800">{t('contact.success.title')}</h3>
      <p class="text-green-700 mt-1">{t('contact.success.message')}</p>
    </div>
  </div>
</div>

<!-- Alerte erreur -->
<div
  id="error-alert"
  class="hidden mt-6 p-6 bg-red-50 border border-red-200 rounded-lg"
  role="alert"
  aria-live="polite"
>
  <div class="flex items-start gap-3">
    <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
      <h3 class="font-semibold text-red-800">{t('contact.error.title')}</h3>
      <p class="text-red-700 mt-1">{t('contact.error.message')}</p>
      <button
        id="retry-btn"
        class="mt-3 text-sm font-medium text-red-700 underline hover:text-red-900"
        type="button"
      >
        {lang === 'fr' ? 'Réessayer' : 'Try again'}
      </button>
    </div>
  </div>
</div>

<!-- Turnstile script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (!form) throw new Error('contact-form not found');

  const action = form.dataset.action ?? '/api/contact.php';
  const lang = form.dataset.lang ?? 'fr';

  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const successAlert = document.getElementById('success-alert') as HTMLElement;
  const errorAlert = document.getElementById('error-alert') as HTMLElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

  // ---- Validation helpers ----
  function showError(fieldId: string, message: string) {
    const el = document.getElementById(`${fieldId}-error`);
    const input = document.getElementById(fieldId);
    if (el) { el.textContent = message; el.classList.remove('hidden'); }
    if (input) input.classList.add('border-red-500');
  }
  function clearError(fieldId: string) {
    const el = document.getElementById(`${fieldId}-error`);
    const input = document.getElementById(fieldId);
    if (el) { el.textContent = ''; el.classList.add('hidden'); }
    if (input) input.classList.remove('border-red-500');
  }
  function clearAllErrors() {
    ['name', 'email', 'message'].forEach(clearError);
  }

  function validate(): boolean {
    clearAllErrors();
    let valid = true;

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name) {
      showError('name', lang === 'fr' ? 'Le nom est requis.' : 'Name is required.');
      valid = false;
    }
    if (!email) {
      showError('email', lang === 'fr' ? 'L\'adresse courriel est requise.' : 'Email address is required.');
      valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', lang === 'fr' ? 'Adresse courriel invalide.' : 'Invalid email address.');
      valid = false;
    }
    if (!message) {
      showError('message', lang === 'fr' ? 'Le message est requis.' : 'Message is required.');
      valid = false;
    } else if (message.length < 20) {
      showError('message', lang === 'fr' ? 'Le message doit contenir au moins 20 caractères.' : 'Message must be at least 20 characters.');
      valid = false;
    }

    return valid;
  }

  // ---- UI state helpers ----
  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    btnSpinner.classList.toggle('hidden', !loading);
  }
  function showSuccess() {
    form.classList.add('hidden');
    successAlert.classList.remove('hidden');
    errorAlert.classList.add('hidden');
  }
  function showServerError() {
    errorAlert.classList.remove('hidden');
    successAlert.classList.add('hidden');
    setLoading(false);
  }

  // ---- Retry ----
  retryBtn?.addEventListener('click', () => {
    errorAlert.classList.add('hidden');
    form.classList.remove('hidden');
    clearAllErrors();
  });

  // ---- Submit ----
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validate()) return;

    setLoading(true);
    errorAlert.classList.add('hidden');

    const data: Record<string, string> = {
      name: (document.getElementById('name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('email') as HTMLInputElement).value.trim(),
      phone: (document.getElementById('phone') as HTMLInputElement).value.trim(),
      company: (document.getElementById('company') as HTMLInputElement).value.trim(),
      message: (document.getElementById('message') as HTMLTextAreaElement).value.trim(),
      website: (document.getElementById('website') as HTMLInputElement).value,
      lang,
    };

    // Turnstile token (may be absent in dev)
    const turnstileInput = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
    if (turnstileInput) data['cf-turnstile-response'] = turnstileInput.value;

    try {
      const res = await fetch(action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const json = await res.json().catch(() => ({ success: false }));

      if (res.ok && json.success) {
        showSuccess();
      } else {
        showServerError();
      }
    } catch (_) {
      showServerError();
    }
  });
</script>
