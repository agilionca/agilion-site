---
import { useTranslations, getLocalePath, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  { key: 'services.custom-software.title' as const, path: '/services' },
  { key: 'services.integration.title' as const, path: '/services' },
  { key: 'services.cloud.title' as const, path: '/services' },
  { key: 'services.cybersecurity.title' as const, path: '/services' },
  { key: 'services.web.title' as const, path: '/services' },
  { key: 'services.consulting.title' as const, path: '/services' },
];

const company = [
  { key: 'nav.about' as const, path: '/a-propos' },
  { key: 'nav.blog' as const, path: '/blogue' },
  { key: 'nav.contact' as const, path: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="relative text-white overflow-hidden" role="contentinfo" style="background: #0F172A;">
  <!-- Gradient top border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500 to-transparent" aria-hidden="true"></div>
  <!-- Subtle background mesh -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 60% 40% at 80% 20%, rgba(99,102,241,0.08) 0%, transparent 60%), radial-gradient(ellipse 40% 30% at 20% 80%, rgba(6,182,212,0.05) 0%, transparent 60%);"></div>

  <div class="container-site relative py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <a
          href={getLocalePath('/', lang)}
          class="flex items-center gap-3 mb-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          aria-label="Agilion"
        >
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-indigo-500 to-cyan-500 flex items-center justify-center text-white font-bold text-base" aria-hidden="true">A</div>
          <span class="font-bold text-xl text-white">Agilion</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs">
          {t('footer.tagline')}
        </p>

        <!-- Social links -->
        <div class="mt-6 flex items-center gap-3">
          <a
            href="https://linkedin.com/company/agilion"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link w-9 h-9 rounded-lg flex items-center justify-center text-white/60 hover:text-white transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
            aria-label={lang === 'fr' ? 'Agilion sur LinkedIn' : 'Agilion on LinkedIn'}
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="https://github.com/agilionca"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link w-9 h-9 rounded-lg flex items-center justify-center text-white/60 hover:text-white transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
            aria-label={lang === 'fr' ? 'Agilion sur GitHub' : 'Agilion on GitHub'}
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-5">
          {t('nav.services')}
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            services.map(({ key, path }) => (
              <li>
                <a
                  href={getLocalePath(path, lang)}
                  class="text-white/60 hover:text-white text-sm transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
                >
                  {t(key)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-5">
          {t('footer.col.company')}
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            company.map(({ key, path }) => (
              <li>
                <a
                  href={getLocalePath(path, lang)}
                  class="text-white/60 hover:text-white text-sm transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
                >
                  {t(key)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-5">
          {t('nav.contact')}
        </h3>
        <ul class="space-y-3 text-sm" role="list">
          <li>
            <span class="block text-white/40 text-xs uppercase tracking-wide mb-1">
              {lang === 'fr' ? 'Courriel' : 'Email'}
            </span>
            <span
              id="contact-email"
              data-e="aW5mb0BhZ2lsaW9uLmNh"
              class="text-white/60 hover:text-white transition-colors"
            ></span>
          </li>
          <li>
            <span class="block text-white/40 text-xs uppercase tracking-wide mb-1">
              {lang === 'fr' ? 'Téléphone' : 'Phone'}
            </span>
            <span
              id="contact-tel"
              data-t="KzEgKDUxNCkgMDAwLTAwMDA="
              class="text-white/60 hover:text-white transition-colors"
            ></span>
          </li>
          <li class="text-white/40 text-sm">
            Québec, Canada · {lang === 'fr' ? 'Canada & USA' : 'Canada & USA'}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/40">
      <p>
        &copy; {year} Agilion Inc. {t('footer.rights')}
      </p>
      <a
        href={lang === 'fr' ? '/politique-confidentialite' : '/en/privacy-policy'}
        class="hover:text-white/70 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
      >
        {t('footer.privacy')}
      </a>
    </div>
  </div>

  <style>
    .social-link:hover {
      background: rgba(99,102,241,0.2) !important;
      border-color: rgba(99,102,241,0.4) !important;
      box-shadow: 0 0 20px rgba(99,102,241,0.3);
    }
  </style>

  <!-- PII de-obfuscation via base64 -->
  <script>
    const em = document.getElementById('contact-email');
    const te = document.getElementById('contact-tel');
    if (em) {
      const v = atob((em as HTMLElement).dataset.e!);
      em.innerHTML = `<a href="mailto:${v}" class="hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded">${v}</a>`;
    }
    if (te) {
      const v = atob((te as HTMLElement).dataset.t!);
      te.innerHTML = `<a href="tel:${v.replace(/\s/g, '')}" class="hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded">${v}</a>`;
    }
  </script>
</footer>
