---
import { useTranslations, getLocalePath, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  { key: 'services.custom-software.title' as const, path: '/services/logiciel-sur-mesure' },
  { key: 'services.integration.title' as const, path: '/services/integration' },
  { key: 'services.cloud.title' as const, path: '/services/cloud' },
  { key: 'services.cybersecurity.title' as const, path: '/services/cybersecurite' },
  { key: 'services.web.title' as const, path: '/services/web' },
  { key: 'services.consulting.title' as const, path: '/services/consultation' },
];

const company = [
  { key: 'nav.about' as const, path: '/a-propos' },
  { key: 'nav.blog' as const, path: '/blogue' },
  { key: 'nav.contact' as const, path: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="bg-primary text-white" role="contentinfo">
  <div class="container-site py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <a
          href={getLocalePath('/', lang)}
          class="flex items-center gap-2 mb-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          aria-label="Agilion"
        >
          <svg
            width="32"
            height="32"
            viewBox="0 0 36 36"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect width="36" height="36" rx="8" fill="#2563EB" />
            <path
              d="M10 26L18 10L26 26"
              stroke="white"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M13 21H23"
              stroke="white"
              stroke-width="3"
              stroke-linecap="round"
            />
          </svg>
          <span class="font-bold text-xl">Agilion</span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          {t('footer.tagline')}
        </p>

        <!-- Social links -->
        <div class="mt-6 flex items-center gap-4">
          <a
            href="https://linkedin.com/company/agilion"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white rounded"
            aria-label="Agilion sur LinkedIn"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="https://github.com/agilionca"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white rounded"
            aria-label="Agilion sur GitHub"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">
          {t('nav.services')}
        </h3>
        <ul class="space-y-2" role="list">
          {
            services.map(({ key, path }) => (
              <li>
                <a
                  href={getLocalePath(path, lang)}
                  class="text-white/70 hover:text-white text-sm transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
                >
                  {t(key)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">
          {lang === 'fr' ? 'Entreprise' : 'Company'}
        </h3>
        <ul class="space-y-2" role="list">
          {
            company.map(({ key, path }) => (
              <li>
                <a
                  href={getLocalePath(path, lang)}
                  class="text-white/70 hover:text-white text-sm transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
                >
                  {t(key)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact column — PII obfuscated via JS -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">
          {t('nav.contact')}
        </h3>
        <ul class="space-y-3 text-sm text-white/70" role="list">
          <li>
            <span class="block text-white/50 text-xs uppercase tracking-wide mb-1">
              {lang === 'fr' ? 'Courriel' : 'Email'}
            </span>
            <!-- Email obfuscated — revealed by JS to prevent scraping -->
            <a
              id="footer-email"
              href="#contact"
              class="hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
              data-user="info"
              data-domain="agilion.ca"
              aria-label={lang === 'fr' ? 'Envoyer un courriel' : 'Send an email'}
            >
              {lang === 'fr' ? 'Cliquez pour nous écrire' : 'Click to email us'}
            </a>
          </li>
          <li>
            <span class="block text-white/50 text-xs uppercase tracking-wide mb-1">
              {lang === 'fr' ? 'Téléphone' : 'Phone'}
            </span>
            <!-- Phone obfuscated — revealed by JS to prevent scraping -->
            <a
              id="footer-phone"
              href="#contact"
              class="hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
              data-tel="15149999999"
              aria-label={lang === 'fr' ? 'Appeler Agilion' : 'Call Agilion'}
            >
              {lang === 'fr' ? 'Cliquez pour appeler' : 'Click to call'}
            </a>
          </li>
          <li class="text-white/60">
            Québec, Canada · {lang === 'fr' ? 'Canada & USA' : 'Canada & USA'}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/50">
      <p>
        &copy; {year} Agilion Inc. {t('footer.rights')}
      </p>
      <a
        href={getLocalePath('/politique-de-confidentialite', lang)}
        class="hover:text-white/80 transition-colors focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white rounded"
      >
        {t('footer.privacy')}
      </a>
    </div>
  </div>

  <!-- PII obfuscation script -->
  <script>
    (function () {
      const emailEl = document.getElementById('footer-email') as HTMLAnchorElement | null;
      if (emailEl) {
        const user = emailEl.dataset['user'];
        const domain = emailEl.dataset['domain'];
        if (user && domain) {
          const email = `${user}@${domain}`;
          emailEl.href = `mailto:${email}`;
          emailEl.textContent = email;
        }
      }

      const phoneEl = document.getElementById('footer-phone') as HTMLAnchorElement | null;
      if (phoneEl) {
        const tel = phoneEl.dataset['tel'];
        if (tel) {
          phoneEl.href = `tel:+${tel}`;
          // Format: +1 (514) 999-9999
          phoneEl.textContent = `+1 (514) 999-9999`;
        }
      }
    })();
  </script>
</footer>
