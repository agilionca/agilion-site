---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
  currentPath: string;
  alternateUrl?: string;
}

const { lang, currentPath, alternateUrl } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { key: 'nav.home' as const, frPath: '/', enPath: '/en' },
  { key: 'nav.services' as const, frPath: '/services', enPath: '/en/services' },
  { key: 'nav.about' as const, frPath: '/a-propos', enPath: '/en/about' },
  { key: 'nav.blog' as const, frPath: '/blogue', enPath: '/en/blog' },
  { key: 'nav.contact' as const, frPath: '/contact', enPath: '/en/contact' },
];

const contactHref = lang === 'fr' ? '/contact' : '/en/contact';
const homeHref = lang === 'fr' ? '/' : '/en';
---

<header
  id="main-header"
  class="sticky top-0 z-50"
  role="banner"
>
  <div class="container-site">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href={lang === 'fr' ? '/' : '/en'}
         aria-label={lang === 'fr' ? "Agilion — Retour à l'accueil" : "Agilion — Back to home"}
         class="flex items-center gap-2 shrink-0">
        <img
          src="/logo-agilion.png"
          alt="Agilion"
          width="80"
          height="61"
          class="h-10 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav
        class="hidden md:flex items-center gap-1"
        aria-label={lang === 'fr' ? 'Navigation principale' : 'Main navigation'}
      >
        {
          navItems.map(({ key, frPath, enPath }) => {
            const href = lang === 'fr' ? frPath : enPath;
            const isActive = currentPath === href
              || (frPath === '/' && lang === 'fr' && currentPath === '')
              || (enPath === '/en' && lang === 'en' && currentPath === '/en');
            return (
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class={`nav-link px-4 py-2 text-sm font-medium transition-colors duration-200 ${
                  isActive ? 'text-white' : 'text-white/80'
                }`}
              >
                {t(key)}
              </a>
            );
          })
        }
      </nav>

      <!-- Right side: Language switcher + CTA + hamburger -->
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex">
          <LanguageSwitcher lang={lang} currentPath={currentPath} alternateUrl={alternateUrl} />
        </div>
        <a
          href={contactHref}
          class="hidden md:inline-flex items-center gap-2 btn-primary text-sm py-2 px-5"
        >
          <span>{t('common.getQuote')}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Hamburger (mobile) -->
        <label
          for="mobile-menu-toggle"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 cursor-pointer rounded-lg hover:bg-white/10 transition-colors"
        >
          <span class="sr-only">Menu</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="white" stroke-width="2" stroke-linecap="round" />
          </svg>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" aria-label={lang === 'fr' ? 'Ouvrir le menu de navigation' : 'Open navigation menu'} aria-expanded="false" />
  <div
    id="mobile-nav-panel"
    aria-hidden="true"
    class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-screen transition-all duration-300 ease-in-out border-t border-white/10"
    style="background: rgba(15,23,42,0.98); backdrop-filter: blur(20px);"
  >
    <nav
      id="mobile-nav"
      class="container-site py-4 flex flex-col gap-1"
      aria-label={lang === 'fr' ? 'Navigation mobile' : 'Mobile navigation'}
    >
      {
        navItems.map(({ key, frPath, enPath }) => {
          const href = lang === 'fr' ? frPath : enPath;
          return (
            <a
              href={href}
              class="px-4 py-3 rounded-lg text-white/90 hover:text-white hover:bg-white/10 font-medium transition-colors"
            >
              {t(key)}
            </a>
          );
        })
      }
      <div class="mt-3 pt-3 border-t border-white/10 flex items-center justify-between">
        <LanguageSwitcher lang={lang} currentPath={currentPath} alternateUrl={alternateUrl} />
        <a
          href={contactHref}
          class="btn-primary text-sm py-2 px-4"
        >
          <span>{t('common.getQuote')}</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  header {
    transition: background 0.3s, box-shadow 0.3s;
    background: transparent;
  }
  header.scrolled {
    background: rgba(15,23,42,0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.08);
  }
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #6366F1, #06B6D4);
    transition: width 0.3s ease;
  }
  .nav-link:hover { color: white; }
  .nav-link:hover::after { width: 100%; }
  .nav-link[aria-current="page"]::after { width: 100%; }
</style>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement | null;
  const panel = document.getElementById('mobile-nav-panel');
  if (toggle && panel) {
    toggle.addEventListener('change', () => {
      toggle.setAttribute('aria-expanded', String(toggle.checked));
      panel.setAttribute('aria-hidden', String(!toggle.checked));
    });
    document.querySelectorAll('#mobile-nav a').forEach(a => {
      a.addEventListener('click', () => {
        toggle.checked = false;
        toggle.setAttribute('aria-expanded', 'false');
        panel.setAttribute('aria-hidden', 'true');
      });
    });
  }
</script>
