---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

// Explicit FR and EN paths for each nav item
// (about and blog differ between FR and EN, so we don't use getLocalePath)
const navItems = [
  { key: 'nav.home' as const, frPath: '/', enPath: '/en' },
  { key: 'nav.services' as const, frPath: '/services', enPath: '/en/services' },
  { key: 'nav.about' as const, frPath: '/a-propos', enPath: '/en/about' },
  { key: 'nav.blog' as const, frPath: '/blogue', enPath: '/en/blog' },
  { key: 'nav.contact' as const, frPath: '/contact', enPath: '/en/contact' },
];

const contactHref = lang === 'fr' ? '/contact' : '/en/contact';
const homeHref = lang === 'fr' ? '/' : '/en';
---

<header
  class="sticky top-0 z-50 bg-primary/95 backdrop-blur-sm shadow-md"
  role="banner"
>
  <div class="container-site">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a
        href={homeHref}
        class="flex items-center gap-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        aria-label={lang === 'fr' ? "Agilion — Retour à l'accueil" : "Agilion — Back to home"}
      >
        <svg
          width="36"
          height="36"
          viewBox="0 0 36 36"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <rect width="36" height="36" rx="8" fill="#2563EB" />
          <path
            d="M10 26L18 10L26 26"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M13 21H23"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
        <span class="text-white font-bold text-xl tracking-tight">Agilion</span>
      </a>

      <!-- Desktop Navigation -->
      <nav
        class="hidden md:flex items-center gap-1"
        aria-label={lang === 'fr' ? 'Navigation principale' : 'Main navigation'}
      >
        {
          navItems.map(({ key, frPath, enPath }) => {
            const href = lang === 'fr' ? frPath : enPath;
            const isActive = currentPath === href || (frPath === '/' && lang === 'fr' && currentPath === '') || (enPath === '/en' && lang === 'en' && currentPath === '/en');
            return (
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white ${
                  isActive
                    ? 'bg-white/15 text-white'
                    : 'text-white/80 hover:text-white hover:bg-white/10'
                }`}
              >
                {t(key)}
              </a>
            );
          })
        }
      </nav>

      <!-- Right side: Language switcher + CTA + hamburger -->
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex">
          <LanguageSwitcher lang={lang} currentPath={currentPath} />
        </div>
        <a
          href={contactHref}
          class="hidden md:inline-flex items-center gap-1 px-4 py-2 bg-accent text-white font-semibold text-sm rounded-lg hover:bg-amber-500 active:scale-95 transition-all duration-150 shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          {t('common.getQuote')}
        </a>

        <!-- Hamburger (mobile) — CSS-only using checkbox trick -->
        <label
          for="mobile-menu-toggle"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 cursor-pointer rounded-lg hover:bg-white/10 transition-colors"
          aria-label={lang === 'fr' ? 'Ouvrir le menu' : 'Open menu'}
        >
          <span class="sr-only">Menu</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="white" stroke-width="2" stroke-linecap="round" />
          </svg>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile menu — keyboard accessible: checkbox focusable, label has matching for -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" aria-label={lang === 'fr' ? 'Ouvrir le menu de navigation' : 'Open navigation menu'} />
  <div
    class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-screen transition-all duration-300 ease-in-out bg-primary border-t border-white/10"
  >
    <nav
      id="mobile-nav"
      class="container-site py-4 flex flex-col gap-1"
      aria-label={lang === 'fr' ? 'Navigation mobile' : 'Mobile navigation'}
    >
      {
        navItems.map(({ key, frPath, enPath }) => {
          const href = lang === 'fr' ? frPath : enPath;
          return (
            <a
              href={href}
              class="px-4 py-3 rounded-lg text-white/90 hover:text-white hover:bg-white/10 font-medium transition-colors"
            >
              {t(key)}
            </a>
          );
        })
      }
      <div class="mt-3 pt-3 border-t border-white/10 flex items-center justify-between">
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
        <a
          href={contactHref}
          class="px-4 py-2 bg-accent text-white font-semibold text-sm rounded-lg hover:bg-amber-500 transition-colors"
        >
          {t('common.getQuote')}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll('#mobile-nav a').forEach(a => {
      a.addEventListener('click', () => { toggle.checked = false; });
    });
  }
</script>
