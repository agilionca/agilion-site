---
import { useTranslations, type Lang } from '@i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    key: 'custom-software' as const,
    img: '/images/services/logiciel.webp',
    color: 'from-indigo-500 to-purple-600',
    href: lang === 'fr' ? '/services#logiciel-sur-mesure' : '/en/services#custom-software',
  },
  {
    key: 'integration' as const,
    img: '/images/services/integration.webp',
    color: 'from-cyan-500 to-blue-600',
    href: lang === 'fr' ? '/services#integration' : '/en/services#integration',
  },
  {
    key: 'cloud' as const,
    img: '/images/services/cloud.webp',
    color: 'from-blue-500 to-indigo-600',
    href: lang === 'fr' ? '/services#cloud' : '/en/services#cloud',
  },
  {
    key: 'cybersecurity' as const,
    img: '/images/services/securite.webp',
    color: 'from-red-500 to-orange-600',
    href: lang === 'fr' ? '/services#cybersecurite' : '/en/services#cybersecurity',
  },
  {
    key: 'web' as const,
    img: '/images/services/web.webp',
    color: 'from-purple-500 to-pink-600',
    href: lang === 'fr' ? '/services#web' : '/en/services#web',
  },
  {
    key: 'consulting' as const,
    img: '/images/services/consultation.webp',
    color: 'from-teal-500 to-cyan-600',
    href: lang === 'fr' ? '/services#consultation' : '/en/services#consulting',
  },
] as const;
---

<section class="py-24 bg-section-dark" aria-labelledby="services-heading">
  <div class="container-site">
    <div class="text-center mb-16 reveal">
      <h2 id="services-heading" class="text-4xl md:text-5xl font-bold text-white mb-4">
        {t('services.title')}
      </h2>
      <p class="text-slate-400 text-xl max-w-2xl mx-auto">
        {t('services.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
      {services.map(({ key, img, color, href }) => (
        <a
          href={href}
          class="group relative overflow-hidden rounded-2xl card-3d shimmer reveal cursor-pointer"
          style="text-decoration: none;"
        >
          <!-- Image with overlay -->
          <div class="relative h-56 overflow-hidden">
            <img
              src={img}
              alt={t(`services.${key}.title`)}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              decoding="async"
              width="800"
              height="450"
            />
            <div class={`absolute inset-0 bg-gradient-to-br ${color} opacity-70 group-hover:opacity-50 transition-opacity duration-300`}></div>
          </div>

          <!-- Content -->
          <div class="glass p-6 rounded-b-2xl" style="border-top: none; border-radius: 0 0 1rem 1rem;">
            <h3 class="text-white font-bold text-lg mb-2">{t(`services.${key}.title`)}</h3>
            <p class="text-slate-300 text-sm leading-relaxed">{t(`services.${key}.description`)}</p>
            <div class="flex items-center gap-2 mt-4 text-indigo-400 text-sm font-medium">
              <span>{t('common.learnMore')}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
