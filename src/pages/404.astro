---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLangFromUrl } from '@i18n/index';

// Astro génère /404.html — la langue est détectée depuis l'URL courante
const lang = getLangFromUrl(Astro.url);

const content = {
  fr: {
    title: 'Page introuvable — Agilion',
    description: 'La page que vous cherchez n\'existe pas ou a été déplacée.',
    heading: 'Page introuvable',
    message: 'On a cherché partout, mais cette page s\'est perdue dans l\'espace numérique. Voici quelques pistes pour retrouver votre chemin.',
    home: 'Retour à l\'accueil',
    services: 'Nos services',
    blog: 'Blogue',
    contact: 'Nous contacter',
    homeHref: '/',
    servicesHref: '/services',
    blogHref: '/blogue',
    contactHref: '/contact',
    searchPlaceholder: 'Naviguez vers une page…',
    searchLabel: 'Liens rapides',
    quickLinks: [
      { label: 'Accueil', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'À propos', href: '/a-propos' },
      { label: 'Blogue', href: '/blogue' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  en: {
    title: 'Page not found — Agilion',
    description: 'The page you are looking for does not exist or has been moved.',
    heading: 'Page not found',
    message: 'We searched far and wide, but this page seems to have drifted off into the digital cosmos. Here are a few links to help you find your way back.',
    home: 'Back to home',
    services: 'Our services',
    blog: 'Blog',
    contact: 'Contact us',
    homeHref: '/en',
    servicesHref: '/en/services',
    blogHref: '/en/blog',
    contactHref: '/en/contact',
    searchPlaceholder: 'Navigate to a page…',
    searchLabel: 'Quick links',
    quickLinks: [
      { label: 'Home', href: '/en' },
      { label: 'Services', href: '/en/services' },
      { label: 'About', href: '/en/about' },
      { label: 'Blog', href: '/en/blog' },
      { label: 'Contact', href: '/en/contact' },
    ],
  },
} as const;

const c = content[lang];
---

<BaseLayout
  title={c.title}
  description={c.description}
  lang={lang}
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center justify-center py-20 bg-surface">
    <div class="container-site text-center max-w-2xl">

      <!-- Illustration SVG — astronaute perdu dans l'espace -->
      <div class="flex justify-center mb-10" aria-hidden="true">
        <svg
          width="260"
          height="220"
          viewBox="0 0 260 220"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Personnage perdu dans l'espace"
        >
          <!-- Étoiles de fond -->
          <circle cx="20" cy="30" r="2" fill="#CBD5E1" opacity="0.6" />
          <circle cx="240" cy="20" r="1.5" fill="#CBD5E1" opacity="0.5" />
          <circle cx="200" cy="60" r="2" fill="#CBD5E1" opacity="0.7" />
          <circle cx="40" cy="80" r="1.5" fill="#CBD5E1" opacity="0.4" />
          <circle cx="220" cy="150" r="2" fill="#CBD5E1" opacity="0.5" />
          <circle cx="15" cy="160" r="1.5" fill="#CBD5E1" opacity="0.6" />
          <circle cx="250" cy="100" r="1" fill="#CBD5E1" opacity="0.5" />
          <circle cx="70" cy="20" r="1" fill="#CBD5E1" opacity="0.4" />

          <!-- Planète principale -->
          <circle cx="130" cy="110" r="72" fill="#EFF6FF" stroke="#DBEAFE" stroke-width="2" />
          <ellipse cx="130" cy="110" rx="55" ry="15" fill="none" stroke="#BFDBFE" stroke-width="2" stroke-dasharray="6 4" />

          <!-- Petite lune -->
          <circle cx="210" cy="55" r="18" fill="#F1F5F9" stroke="#E2E8F0" stroke-width="1.5" />
          <circle cx="204" cy="50" r="4" fill="#E2E8F0" opacity="0.7" />
          <circle cx="215" cy="62" r="3" fill="#E2E8F0" opacity="0.5" />

          <!-- Corps de l'astronaute -->
          <!-- Casque -->
          <ellipse cx="130" cy="72" rx="22" ry="22" fill="white" stroke="#1E3A5F" stroke-width="2.5" />
          <ellipse cx="130" cy="72" rx="15" ry="15" fill="#DBEAFE" opacity="0.8" />
          <!-- Reflet vitre -->
          <path d="M120 64 Q124 60 130 62" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.9" />

          <!-- Combinaison -->
          <rect x="110" y="90" width="40" height="35" rx="8" fill="white" stroke="#1E3A5F" stroke-width="2.5" />
          <!-- Patch emblème -->
          <circle cx="124" cy="100" r="5" fill="#2563EB" />
          <text x="124" y="103" text-anchor="middle" font-family="system-ui, sans-serif" font-size="6" font-weight="700" fill="white">A</text>

          <!-- Bras gauche flottant vers le haut -->
          <path d="M110 95 Q95 80 85 70" stroke="white" stroke-width="8" stroke-linecap="round" />
          <path d="M110 95 Q95 80 85 70" stroke="#1E3A5F" stroke-width="2.5" stroke-linecap="round" fill="none" />
          <!-- Gant gauche -->
          <circle cx="84" cy="69" r="6" fill="white" stroke="#1E3A5F" stroke-width="2" />

          <!-- Bras droit flottant vers le bas -->
          <path d="M150 95 Q162 108 170 120" stroke="white" stroke-width="8" stroke-linecap="round" />
          <path d="M150 95 Q162 108 170 120" stroke="#1E3A5F" stroke-width="2.5" stroke-linecap="round" fill="none" />
          <!-- Gant droit -->
          <circle cx="171" cy="121" r="6" fill="white" stroke="#1E3A5F" stroke-width="2" />

          <!-- Jambes flottantes -->
          <path d="M118 125 Q112 140 106 155" stroke="white" stroke-width="8" stroke-linecap="round" />
          <path d="M118 125 Q112 140 106 155" stroke="#1E3A5F" stroke-width="2.5" stroke-linecap="round" fill="none" />
          <path d="M142 125 Q148 140 154 155" stroke="white" stroke-width="8" stroke-linecap="round" />
          <path d="M142 125 Q148 140 154 155" stroke="#1E3A5F" stroke-width="2.5" stroke-linecap="round" fill="none" />
          <!-- Bottes -->
          <ellipse cx="104" cy="157" rx="8" ry="5" fill="white" stroke="#1E3A5F" stroke-width="2" />
          <ellipse cx="156" cy="157" rx="8" ry="5" fill="white" stroke="#1E3A5F" stroke-width="2" />

          <!-- Fil de sécurité (cordée) -->
          <path d="M130 90 Q115 60 100 45 Q90 38 80 40" stroke="#94A3B8" stroke-width="1.5" stroke-dasharray="5 3" fill="none" />

          <!-- Texte 404 dans la planète -->
          <text
            x="130"
            y="116"
            text-anchor="middle"
            font-family="system-ui, sans-serif"
            font-size="26"
            font-weight="800"
            fill="#1E3A5F"
            letter-spacing="-1"
            opacity="0.15"
          >404</text>
        </svg>
      </div>

      <!-- Titre et message -->
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">
        {c.heading}
      </h1>
      <p class="text-lg text-gray-600 mb-10 leading-relaxed max-w-lg mx-auto">
        {c.message}
      </p>

      <!-- Barre de recherche / navigation visuelle -->
      <div class="mb-10 max-w-md mx-auto">
        <label class="block text-sm font-semibold text-gray-500 mb-2 text-left">
          {c.searchLabel}
        </label>
        <div class="relative flex items-center bg-white border border-gray-200 rounded-lg shadow-sm px-4 py-3 gap-3">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-gray-400 shrink-0"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <span class="text-gray-400 text-sm">{c.searchPlaceholder}</span>
        </div>
        <!-- Liens rapides sous la barre -->
        <div class="flex flex-wrap gap-2 mt-3 justify-start">
          {c.quickLinks.map(link => (
            <a
              href={link.href}
              class="text-xs px-3 py-1.5 bg-blue-50 text-primary rounded-full hover:bg-blue-100 transition-colors font-medium"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Boutons de navigation principaux -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={c.homeHref}
          class="px-8 py-4 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 active:scale-95 transition-all duration-150 text-base shadow-md"
        >
          {c.home}
        </a>
        <a
          href={c.servicesHref}
          class="px-8 py-4 bg-white text-primary font-semibold rounded-lg border border-gray-200 hover:bg-gray-50 active:scale-95 transition-all duration-150 text-base shadow-sm"
        >
          {c.services}
        </a>
        <a
          href={c.contactHref}
          class="px-8 py-4 bg-accent text-white font-semibold rounded-lg hover:bg-amber-500 active:scale-95 transition-all duration-150 text-base shadow-sm"
        >
          {c.contact}
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
