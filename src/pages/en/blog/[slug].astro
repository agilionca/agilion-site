---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { estimateReadingTime } from '@utils/reading-time';

export async function getStaticPaths() {
  const articles = await getCollection('blog-en', (e) => !e.data.draft);
  const sorted = articles.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return sorted.map((article, index) => ({
    params: { slug: article.id },
    props: {
      article,
      prev: sorted[index + 1] ?? null,
      next: sorted[index - 1] ?? null,
    },
  }));
}

interface Props {
  article: CollectionEntry<'blog-en'>;
  prev: CollectionEntry<'blog-en'> | null;
  next: CollectionEntry<'blog-en'> | null;
}

const { article, prev, next } = Astro.props;
const { Content } = await render(article);
const { title, description, pubDate, updatedDate, author, tags, category, readingTime, image, translationSlug } = article.data;

const lang = 'en' as const;
const computedReadingTime = readingTime ?? estimateReadingTime(article.body ?? '');
const canonicalURL = new URL(`/en/blog/${article.id}`, Astro.site).toString();
const alternateUrl = translationSlug ? `/blogue/${translationSlug}` : undefined;

const categoryColors: Record<string, string> = {
  logiciel: 'rgba(99,102,241,0.2)',
  cloud: 'rgba(6,182,212,0.2)',
  securite: 'rgba(239,68,68,0.2)',
  web: 'rgba(16,185,129,0.2)',
  consultation: 'rgba(245,158,11,0.2)',
};
const categoryBorderColors: Record<string, string> = {
  logiciel: 'rgba(99,102,241,0.4)',
  cloud: 'rgba(6,182,212,0.4)',
  securite: 'rgba(239,68,68,0.4)',
  web: 'rgba(16,185,129,0.4)',
  consultation: 'rgba(245,158,11,0.4)',
};
const categoryTextColors: Record<string, string> = {
  logiciel: '#a5b4fc',
  cloud: '#67e8f9',
  securite: '#fca5a5',
  web: '#6ee7b7',
  consultation: '#fcd34d',
};

const bgColor = categoryColors[category] ?? 'rgba(99,102,241,0.2)';
const borderColor = categoryBorderColors[category] ?? 'rgba(99,102,241,0.4)';
const textColor = categoryTextColors[category] ?? '#a5b4fc';
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonicalURL={canonicalURL}
  ogImage={image}
  ogType="article"
  publishedDate={pubDate.toISOString()}
  modifiedDate={updatedDate?.toISOString()}
  articleTags={tags}
  alternateSlug={translationSlug ? `/blogue/${translationSlug}` : undefined}
  alternateUrl={alternateUrl}
>
  <!-- Hero article avec gradient -->
  <div class="relative pt-32 pb-16 bg-mesh dot-pattern overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0F172A] z-10"></div>
    <div class="relative z-20 container-site max-w-4xl">
      <!-- Back link -->
      <a href="/en/blog" class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-indigo-300 transition-colors mb-8 reveal">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to blog
      </a>

      <!-- Category + reading time -->
      <div class="flex items-center gap-3 mb-6 reveal">
        <span class="px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider"
              style={`background: ${bgColor}; color: ${textColor}; border: 1px solid ${borderColor}`}>
          {category}
        </span>
        <span class="text-slate-400 text-sm">{computedReadingTime} min read</span>
      </div>

      <!-- Title H1 -->
      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6 reveal">{title}</h1>

      <!-- Description lead -->
      <p class="text-lg text-slate-300 leading-relaxed mb-6 reveal max-w-3xl">{description}</p>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 text-slate-400 text-sm reveal">
        <span class="flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          {pubDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span>·</span>
        <span>{author}</span>
        {translationSlug && (
          <a href={`/blogue/${translationSlug}`} class="ml-auto flex items-center gap-1 text-indigo-400 hover:text-indigo-300 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            Lire en français
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Content + sidebar -->
  <div class="bg-section-dark min-h-screen">
    <div class="container-site max-w-6xl py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">

        <!-- MDX Article content -->
        <article class="prose-custom reveal">
          <Content />
        </article>

        <!-- Sidebar sticky -->
        <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
          <!-- Tags -->
          {tags && tags.length > 0 && (
            <div class="glass p-6 rounded-2xl reveal">
              <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <span class="px-3 py-1 rounded-full text-xs text-indigo-300 border border-indigo-500/30" style="background: rgba(99,102,241,0.1)">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- CTA sidebar -->
          <div class="glass p-6 rounded-2xl reveal" style="border: 1px solid rgba(99,102,241,0.3)">
            <h3 class="text-white font-bold mb-2">Need expertise?</h3>
            <p class="text-slate-400 text-sm mb-4">Let's discuss your project. First call is free.</p>
            <a href="/en/contact" class="btn-primary w-full text-center text-sm py-3 block">
              <span>Contact us</span>
            </a>
          </div>

          <!-- Updated date -->
          {updatedDate && (
            <div class="glass p-4 rounded-xl reveal">
              <p class="text-slate-500 text-xs">
                Updated {updatedDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </div>
          )}
        </aside>
      </div>

      <!-- Prev / Next -->
      {(prev || next) && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-16 pt-16 border-t border-white/10 reveal">
          {prev && (
            <a href={`/en/blog/${prev.id}`} class="glass p-6 rounded-2xl card-3d group block">
              <p class="text-slate-400 text-xs mb-2">← Previous article</p>
              <p class="text-white font-semibold group-hover:text-indigo-300 transition-colors">{prev.data.title}</p>
            </a>
          )}
          {next && (
            <a href={`/en/blog/${next.id}`} class={`glass p-6 rounded-2xl card-3d group block ${!prev ? 'md:col-start-2' : ''}`}>
              <p class="text-slate-400 text-xs mb-2 md:text-right">Next article →</p>
              <p class="text-white font-semibold group-hover:text-indigo-300 transition-colors md:text-right">{next.data.title}</p>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
