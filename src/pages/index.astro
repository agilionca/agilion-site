---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@i18n/index';

const lang = 'fr' as const;
const t = useTranslations(lang);
---

<BaseLayout
  title="Agilion — Firme TI québécoise | Cloud, Logiciel, Cybersécurité"
  description="Agilion accompagne les entreprises canadiennes et américaines dans leur transformation numérique. Développement logiciel sur mesure, cloud AWS/Azure/GCP, cybersécurité et consultation TI."
  lang={lang}
>
  <!-- Hero placeholder -->
  <section class="bg-primary text-white py-24 md:py-36">
    <div class="container-site text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 text-balance">
        {t('hero.title')}
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="px-8 py-4 bg-accent text-white font-semibold rounded-lg hover:bg-amber-500 transition-colors text-lg"
        >
          {t('hero.cta.primary')}
        </a>
        <a
          href="/services"
          class="px-8 py-4 bg-white/10 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors text-lg border border-white/30"
        >
          {t('hero.cta.secondary')}
        </a>
      </div>
    </div>
  </section>

  <!-- Services placeholder -->
  <section class="py-20 bg-surface">
    <div class="container-site text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">{t('services.title')}</h2>
      <p class="text-gray-600 max-w-xl mx-auto">{t('services.subtitle')}</p>
    </div>
  </section>
</BaseLayout>
