---
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceSection from '@components/services/ServiceSection.astro';
import { useTranslations } from '@i18n/index';

const lang = 'fr' as const;
const t = useTranslations(lang);

const contactHref = '/contact';

const services = [
  {
    id: 'logiciel-sur-mesure',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    img: '/images/services/logiciel.webp',
    title: t('services.custom-software.title'),
    description: t('services.custom-software.longDescription'),
    bullets: [
      t('services.custom-software.bullet1'),
      t('services.custom-software.bullet2'),
      t('services.custom-software.bullet3'),
      t('services.custom-software.bullet4'),
      t('services.custom-software.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: false,
  },
  {
    id: 'integration',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="3"/><circle cx="19" cy="19" r="3"/><circle cx="5" cy="19" r="3"/><line x1="12" y1="8" x2="12" y2="14"/><line x1="12" y1="14" x2="19" y2="16"/><line x1="12" y1="14" x2="5" y2="16"/></svg>`,
    img: '/images/services/integration.webp',
    title: t('services.integration.title'),
    description: t('services.integration.longDescription'),
    bullets: [
      t('services.integration.bullet1'),
      t('services.integration.bullet2'),
      t('services.integration.bullet3'),
      t('services.integration.bullet4'),
      t('services.integration.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: true,
  },
  {
    id: 'cloud',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>`,
    img: '/images/services/cloud.webp',
    title: t('services.cloud.title'),
    description: t('services.cloud.longDescription'),
    bullets: [
      t('services.cloud.bullet1'),
      t('services.cloud.bullet2'),
      t('services.cloud.bullet3'),
      t('services.cloud.bullet4'),
      t('services.cloud.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: false,
  },
  {
    id: 'cybersecurite',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    img: '/images/services/securite.webp',
    title: t('services.cybersecurity.title'),
    description: t('services.cybersecurity.longDescription'),
    bullets: [
      t('services.cybersecurity.bullet1'),
      t('services.cybersecurity.bullet2'),
      t('services.cybersecurity.bullet3'),
      t('services.cybersecurity.bullet4'),
      t('services.cybersecurity.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: true,
  },
  {
    id: 'web',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    img: '/images/services/web.webp',
    title: t('services.web.title'),
    description: t('services.web.longDescription'),
    bullets: [
      t('services.web.bullet1'),
      t('services.web.bullet2'),
      t('services.web.bullet3'),
      t('services.web.bullet4'),
      t('services.web.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: false,
  },
  {
    id: 'consultation',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><line x1="3" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="21"/></svg>`,
    img: '/images/services/consultation.webp',
    title: t('services.consulting.title'),
    description: t('services.consulting.longDescription'),
    bullets: [
      t('services.consulting.bullet1'),
      t('services.consulting.bullet2'),
      t('services.consulting.bullet3'),
      t('services.consulting.bullet4'),
      t('services.consulting.bullet5'),
    ],
    ctaText: t('common.startProject'),
    ctaHref: contactHref,
    reversed: true,
  },
];
---

<BaseLayout
  title="Nos services TI : logiciel, cloud, cybersécurité — Agilion"
  description="Développement logiciel sur mesure, intégration d'APIs, cloud AWS/Azure/GCP, cybersécurité et consultation TI pour les entreprises québécoises."
  lang={lang}
>
  <!-- Hero compact -->
  <section class="relative py-32 bg-mesh dot-pattern overflow-hidden" aria-labelledby="services-hero-heading">
    <div class="absolute top-1/4 right-1/4 w-64 h-64 rounded-full blur-3xl float-slow pointer-events-none" style="background: rgba(99,102,241,0.2);" aria-hidden="true"></div>
    <div class="container-site relative z-10">
      <div class="reveal">
        <h1 id="services-hero-heading" class="text-4xl md:text-6xl font-bold text-white mb-4">
          {t('services.page.title')}
        </h1>
        <p class="text-xl max-w-xl" style="color: #94a3b8;">
          {t('services.page.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Alternating service sections -->
  {services.map((service, i) => (
    <div class={i % 2 === 0 ? 'bg-section-dark' : 'bg-section-mid'}>
      <ServiceSection
        id={service.id}
        icon={service.icon}
        img={service.img}
        title={service.title}
        description={service.description}
        bullets={service.bullets}
        ctaText={service.ctaText}
        ctaHref={service.ctaHref}
        reversed={service.reversed}
      />
    </div>
  ))}

  <!-- CTA final -->
  <section class="relative py-32 overflow-hidden bg-section-accent" aria-labelledby="services-cta-heading">
    <div class="absolute inset-0 dot-pattern opacity-20" aria-hidden="true"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-px" style="background: linear-gradient(90deg, transparent, #6366F1, transparent);" aria-hidden="true"></div>
    <div class="relative container-site text-center reveal">
      <h2 id="services-cta-heading" class="text-4xl md:text-5xl font-bold text-white mb-6">
        {t('cta.title')}
      </h2>
      <p class="text-xl mb-10 max-w-xl mx-auto" style="color: rgba(219,234,254,0.8);">
        {t('cta.subtitle')}
      </p>
      <a href="/contact" class="btn-primary pulse-glow text-lg px-8 py-4">
        <span>{t('cta.button')}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
